# ==========================================
# QUANTUM FLOW TERMINAL — Production Configuration
# ==========================================

# ==========================================
# Application Settings
# ==========================================
APP_NAME=Quantum Flow Terminal
APP_VERSION=1.0.0
DEBUG=False

# ==========================================
# Database Configuration
# ==========================================
# PostgreSQL Connection String
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://qf_user:YOUR_DB_PASSWORD@postgres:5432/quantum_flow

# ==========================================
# Redis Configuration
# ==========================================
REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379

# ==========================================
# JWT & Security
# ==========================================
# Minimum 32 characters for production!
SECRET_KEY=YOUR_PRODUCTION_SECRET_KEY_MIN_32_CHARACTERS_LONG!

# JWT Token expiration (minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Refresh token expiration (days)
REFRESH_TOKEN_EXPIRE_DAYS=7

# ==========================================
# Google OAuth Configuration
# ==========================================
# Get from: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

# OAuth redirect URL (must match Google Console configuration)
GOOGLE_REDIRECT_URL=https://your-domain.com/api/auth/oauth/google/callback

# ==========================================
# Email Configuration (SMTP)
# ==========================================
# Gmail example:
# - Use App Password (not regular password)
# - Enable "Less secure app access"

SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# ==========================================
# Binance API Configuration
# ==========================================
BINANCE_WS_URL=wss://stream.binance.com:9443/stream
BINANCE_REST_URL=https://api.binance.com/api/v3

# ==========================================
# CORS Configuration
# ==========================================
# Comma-separated list of allowed origins
CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com,http://localhost:3000

# ==========================================
# Deployment Environment
# ==========================================
# Environment: development, staging, production
ENVIRONMENT=production

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ==========================================
# Database Backups
# ==========================================
BACKUP_ENABLED=True
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM UTC
BACKUP_RETENTION_DAYS=30

# ==========================================
# Monitoring & Analytics
# ==========================================
# Sentry error tracking (optional)
SENTRY_DSN=

# ==========================================
# Third-party Integrations
# ==========================================
# Slack notifications (optional)
SLACK_WEBHOOK_URL=

# Discord notifications (optional)
DISCORD_WEBHOOK_URL=

# ==========================================
# Rate Limiting
# ==========================================
RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# ==========================================
# Cache Configuration
# ==========================================
CACHE_TTL_SECONDS=300
CACHE_MAX_SIZE=1000

# ==========================================
# API Documentation
# ==========================================
# Enable Swagger/OpenAPI docs
DOCS_ENABLED=False
REDOC_ENABLED=False

# ==========================================
# Feature Flags
# ==========================================
# Enable new features for testing
FEATURE_ML_PREDICTIONS=False
FEATURE_STRATEGY_BACKTESTING=False
FEATURE_PORTFOLIO_MANAGEMENT=False

# ==========================================
# Notes for Production Deployment
# ==========================================

# 1. Generate a secure SECRET_KEY:
#    python -c "import secrets; print(secrets.token_urlsafe(32))"

# 2. Set up Google OAuth:
#    - Go to https://console.cloud.google.com/
#    - Create OAuth 2.0 credentials
#    - Add your domain to authorized origins
#    - Set the callback URL

# 3. Configure SMTP for email notifications:
#    - Gmail: Use App Password (https://myaccount.google.com/apppasswords)
#    - Other providers: Use your SMTP credentials

# 4. Set up database backups:
#    - Configure S3 or other storage
#    - Set BACKUP_ENABLED=True

# 5. Enable monitoring:
#    - Set up Sentry for error tracking
#    - Configure Slack/Discord webhooks

# 6. Security checklist:
#    - [ ] Change all default passwords
#    - [ ] Enable HTTPS (use certbot for Let's Encrypt)
#    - [ ] Set DEBUG=False
#    - [ ] Rotate SECRET_KEY regularly
#    - [ ] Configure firewall rules
#    - [ ] Set up rate limiting
#    - [ ] Enable database encryption at rest
#    - [ ] Configure backups

# 7. Before deploying:
#    docker-compose up -d
#    docker-compose exec backend alembic upgrade head  # Run migrations
