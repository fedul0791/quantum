# ============================================
# QUANTUM FLOW TERMINAL — ENVIRONMENT CONFIG
# ============================================
# Copy this file to .env and fill in actual values
# NEVER commit .env with real secrets to git!

# ============================================
# APPLICATION
# ============================================
DEBUG=False
APP_NAME=Quantum Flow Terminal
APP_VERSION=1.0.0

# ============================================
# SECURITY (REQUIRED FOR PRODUCTION)
# ============================================
# Generate with: openssl rand -hex 32
SECRET_KEY=your-32-char-secret-key-here-change-in-production

# ============================================
# DATABASE
# ============================================
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://qf_user:changeme@localhost:5432/quantum_flow
DB_PASSWORD=changeme

# ============================================
# REDIS
# ============================================
REDIS_URL=redis://localhost:6379/0

# ============================================
# GOOGLE OAUTH (Optional, but recommended)
# ============================================
# Get from: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ============================================
# EMAIL / SMTP (Optional, but required for alerts)
# ============================================
# For Gmail: Use app-specific password from https://myaccount.google.com/apppasswords
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
SMTP_FROM_EMAIL=noreply@quantumflow.io
SMTP_FROM_NAME=Quantum Flow

# ============================================
# JWT TOKENS
# ============================================
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# CORS
# ============================================
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ============================================
# API RATE LIMITING
# ============================================
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=INFO

# ============================================
# MARKET DATA (Binance WebSocket)
# ============================================
BINANCE_STREAM_URL=wss://stream.binance.com:9443/stream

# ============================================
# DEPLOYMENT (Staging/Production only)
# ============================================
# HTTPS_ONLY=True
# ALLOWED_HOSTS=api.quantumflow.io,quantumflow.io
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
